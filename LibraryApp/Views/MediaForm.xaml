<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:LibraryApp.Models"
             xmlns:viewModels="clr-namespace:LibraryApp.ViewModels"
             x:Class="LibraryApp.Views.MediaForm"
             x:DataType="viewModels:MediaVM"
             Title="Media Item Form">
    <VerticalStackLayout>
        <Label 
            Text="Media Item"
            FontSize="24"
            FontAttributes="Bold"
            TextDecorations="Underline"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        <Picker Title="Select Media Type"
                ItemsSource="{Binding MediaTypes}"
                SelectedItem="{Binding SelectedMediaType}"/>
        <Entry Placeholder="Title"
               Text="{Binding Title}"/>
        

    </VerticalStackLayout>
</ContentPage>