<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:LibraryApp.ViewModels"
             x:Class="LibraryApp.Views.Administration"
             x:DataType="viewModels:AdminVM"
             Title="Administration">
    <VerticalStackLayout HorizontalOptions="Center">
        <Label 
            Text="Administration"
            FontAttributes="Bold"
            TextDecorations="Underline"
            FontSize="24"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        <Button Text="Media Type" Command="{Binding MediaTypeCommand}"/>
        <Button Text="Genre" Command="{Binding GenreCommand}"/>
    </VerticalStackLayout>
</ContentPage>