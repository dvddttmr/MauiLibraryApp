<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LibraryApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:LibraryApp"
    xmlns:views="clr-namespace:LibraryApp.Views"
    Title="LibraryApp">

    <TabBar>
        <ShellContent
            Title="Books"
            ContentTemplate="{DataTemplate views:MediaList}"/>
        <ShellContent
            Title="Authors"
            ContentTemplate="{DataTemplate views:AuthorList}"/>
        <ShellContent
            Title="Publishers"
            ContentTemplate="{DataTemplate views:PublisherList}"/>
        <ShellContent
            Title="Administration"
            ContentTemplate="{DataTemplate views:Administration}"/>
        <ShellContent
            Title="About"
            ContentTemplate="{DataTemplate views:About}"
            Icon="{FontImageSource Glyph='?',Size=22, Color=Black}"/>
    </TabBar>

</Shell>